# Server SEP-10 signing key — generate one with: npm run gen:sep10key
SEP10_SIGNING_SECRET=
SEP10_HOME_DOMAIN=localhost:4000
WEB_AUTH_DOMAIN=localhost:4000

# --- Anchor (SEP-24) ---
ANCHOR_HOME_DOMAIN=testanchor.stellar.org
ANCHOR_NAME=Stellar Test Anchor
ANCHOR_WEBHOOK_SECRET=change-me

# --- Stable asset (USDC on testnet by default) ---
STABLE_ASSET_CODE=USDC
STABLE_ASSET_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# --- Uploads ---
UPLOADS_DIR=./uploads
