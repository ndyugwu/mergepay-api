# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mergepay

# --- Server ---
PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Stellar ---
STELLAR_NETWORK=testnet
